{
  "name": "@wsms/logger-connect-nuxt",
  "version": "1.0.3",
  "description": "Nuxt connector for @wsms/logger",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "keywords": [
    "nuxt",
    "nuxt3",
    "nuxt4",
    "nuxt-module",
    "logging",
    "logger",
    "typescript",
    "file-logger",
    "nitro"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WhoStoleMySleepDev/logger-connect-nuxt.git"
  },
  "author": "whostolemysleep",
  "license": "MIT",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome lint src/**/*.ts",
    "lint:fix": "biome lint --write src/**/*.ts",
    "format": "biome format --write src/**/*.ts",
    "format:check": "biome format src/**/*.ts",
    "prepare": "husky",
    "prepublishOnly": "npm run build && npm run lint"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "biome lint --write",
      "biome format --write"
    ]
  },
  "dependencies": {
    "@nuxt/kit": "^3.19.0",
    "@nuxt/schema": "^3.19.0",
    "@wsms/logger": "^1.2.0"
  },
  "peerDependencies": {
    "nuxt": "^3.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^25.3.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "nuxt": "^3.21.1",
    "semantic-release": "^25.0.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
